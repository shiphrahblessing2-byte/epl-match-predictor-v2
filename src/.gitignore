# ══════════════════════════════════════════════════════════
# EPL Match Predictor — .gitignore
# ══════════════════════════════════════════════════════════

# ── SECRETS & ENVIRONMENT (CRITICAL — never commit these) ─
.env
.env.*
.env.local
.env.production
.env.staging
*.env
secrets.json
secrets.yaml
secrets.toml
config/secrets.*
api_keys.txt
credentials.json

# ── VIRTUAL ENVIRONMENT ────────────────────────────────────
.venv/
venv/
env/
ENV/
.python-version

# ── PYTHON CACHE ──────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
.eggs/

# ── JUPYTER ───────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints
profile_default/
ipython_config.py

# ── DATA — raw, cache, interim (too large / sensitive) ────
data/raw/
data/interim/
data/cache/
data/processed/*.parquet
data/processed/*.csv
# Uncomment below to also ignore master CSV
# data/processed/epl_features_master.csv

# ── MODELS — binary files (use GitHub Releases instead) ───
models/*.cbm
models/*.pkl
models/*.bin
models/*.h5
models/*.pt
models/*.pth
models/*.joblib
# Keep JSON configs (small, useful for reproducibility)
!models/*.json

# ── REPORTS — generated outputs ───────────────────────────
reports/*.png
reports/*.jpg
reports/*.jpeg
reports/*.pdf
# Keep summary files (small + useful)
!reports/*.csv
!reports/*.txt
!reports/*.json

# ── LOGS ──────────────────────────────────────────────────
*.log
logs/
api.log
nohup.out
uvicorn.log

# ── DOCKER ────────────────────────────────────────────────
# Keep Dockerfile committed — ignore build artifacts only
.dockerignore.local
docker-compose.override.yml

# ── OS FILES ──────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── IDE / EDITOR ──────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# ── TESTING ───────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
test-results/

# ── TYPE CHECKING ─────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/

# ── NODE (Next.js dashboard) ──────────────────────────────
node_modules/
.next/
.nuxt/
out/
dist/
.vercel/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── TEMPORARY ─────────────────────────────────────────────
tmp/
temp/
*.tmp
*.bak
*.backup
scratch/
